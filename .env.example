# Database
# Local development: SQLite works out of the box.
# Railway production: replace this with the PostgreSQL connection string from your Railway database.
DATABASE_URL=sqlite:///./uae_realestate.db

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720

# --- Admin WhatsApp alerts (Meta WhatsApp Cloud API test number) ---
# developers.facebook.com > App > WhatsApp > API Setup
# Free-form text only delivers within 24h after you message the test number first;
# otherwise you need an approved template.
ADMIN_WHATSAPP_NUMBER=+9715XXXXXXXX
META_ACCESS_TOKEN=your_temporary_or_system_user_token
META_PHONE_NUMBER_ID=your_test_number_phone_id
META_API_VERSION=v21.0
# Webhook verification token — set the SAME value in the Meta dashboard webhook config
META_VERIFY_TOKEN=any_string_you_choose

# Internal API base (chatbot graph calls back into FastAPI)
API_BASE_URL=http://localhost:8000

# LLM (opencode / any OpenAI-compatible endpoint)
LLM_API_BASE=https://api.opencode.example/v1
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=your-model-name
